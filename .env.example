# --- Database -------------------------------------------------------------------
# Leave unset (or commented out) to use PGLite — a local file-based Postgres
# database stored in .local-db/ (auto-created, gitignored). Recommended for
# local development: no external DB required.
#
# Set this to connect to the production Neon DB instead (via `pnpm dev:netlify`).
# NETLIFY_DATABASE_URL=postgresql://user:password@host/dbname

# --- Email ----------------------------------------------------------------------
# Resend API key — only needed for contact form + freshness reminder emails.
# Not required for local development.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FEEDBACK_EMAIL=x@gmail.com

# --- Public config --------------------------------------------------------------
# These default to Pittsburgh if not set.
# PUBLIC_CITY_NAME=Pittsburgh
# PUBLIC_CITY_DOMAIN=pgh.comedyconnector.app
# PUBLIC_SITE_URL=https://pgh.comedyconnector.app
