# --- Supabase -------------------------------------------------------------------
# Set this to staging Data API url, Supabase -> Settings -> Data API
; SUPABASE_URL=https://[key].supabase.co

# Supabase > Settings > API Keys > Publishable Key
; SUPABASE_ANON_KEY=<staging publishable key>
# Supabase > Settings > API Keys > Secret key
; SUPABASE_SERVICE_ROLE_KEY=<staging secret role key>
; DEV_USER_PASSWORD=<choose a strong shared password for test users>

# --- Supabase Database URL -----------------------------------------------------
# Set this to connect to the staging Supabase transaction pooler URL (port 6543).
; SUPABASE_DATABASE_URL=postgresql://postgres.[user]:[password]@aws-[server].pooler.supavase.com:6543/postgres

# --- Email ----------------------------------------------------------------------
# Resend API key — only needed for contact form + freshness reminder emails.
# Not required for local development.
; RESEND_API_KEY=re_xxxxxxxxxxxx
; FEEDBACK_EMAIL=x@gmail.com

# --- Public config --------------------------------------------------------------
# These default to Pittsburgh if not set.
; PUBLIC_CITY_NAME=Pittsburgh
; PUBLIC_CITY_DOMAIN=pgh.comedyconnector.app
; PUBLIC_SITE_URL=https://pgh.comedyconnector.app

# Declare so SvelteKit creates types
PUBLIC_DEPLOY_CONTEXT=
