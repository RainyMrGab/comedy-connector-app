{
	"name": "comedy-connector-app",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.30.1",
	"scripts": {
		"dev": "vite dev",
		"predev:prod": "rm -rf build",
		"dev:prod": "PUBLIC_DEPLOY_CONTEXT=preview vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"netlify": "netlify",
		"db:setup": "drizzle-kit push && drizzle-kit migrate",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed:staging": "tsx --env-file .env scripts/seed-staging.ts"
	},
	"devDependencies": {
		"@netlify/functions": "^2.8.2",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.0.12",
		"drizzle-kit": "^0.31.10",
		"netlify-cli": "^26.0.2",
		"svelte": "^5.55.7",
		"svelte-check": "^4.1.4",
		"tailwindcss": "^4.0.12",
		"tsx": "^4.22.3",
		"typescript": "^5.7.3",
		"vite": "^7.3.3"
	},
	"dependencies": {
		"@skeletonlabs/skeleton": "^4.0.0",
		"@skeletonlabs/skeleton-svelte": "^4.11.0",
		"@supabase/ssr": "^0.10.3",
		"@supabase/supabase-js": "^2.106.1",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^0.483.0",
		"postgres": "^3.4.9",
		"resend": "^4.1.2",
		"zod": "^3.24.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"netlify-cli",
			"sharp"
		],
		"ignoredBuiltDependencies": [
			"@parcel/watcher",
			"unix-dgram"
		],
		"overrides": {
			"esbuild@<=0.24.2": ">=0.25.0",
			"cookie@<0.7.0": ">=0.7.0",
			"svelte@>=5.53.0 <5.53.5": ">=5.53.5",
			"svelte@<=5.55.6": ">=5.55.7",
			"@sveltejs/kit@>=2.49.0 <=2.53.2": ">=2.53.3",
			"devalue@>=5.6.3 <=5.8.0": ">=5.8.1",
			"tar@<=7.5.10": ">=7.5.11",
			"svgo@=4.0.0": ">=4.0.1",
			"fastify@>=5.7.2 <=5.8.0": ">=5.8.1"
		}
	}
}
