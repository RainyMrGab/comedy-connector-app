{
	"name": "comedy-connector-app",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.30.1",
	"scripts": {
		"dev": "vite dev",
		"predev:netlify": "rm -rf build",
		"dev:netlify": "netlify dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"netlify": "netlify",
		"db:setup": "drizzle-kit push && drizzle-kit migrate",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@netlify/functions": "^2.8.2",
		"@sveltejs/adapter-netlify": "^4.3.6",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.12",
		"drizzle-kit": "^0.30.4",
		"netlify-cli": "^23.15.1",
		"svelte": "^5.20.2",
		"svelte-check": "^4.1.4",
		"tailwindcss": "^4.0.12",
		"typescript": "^5.7.3",
		"vite": "^6.2.0"
	},
	"dependencies": {
		"@neondatabase/serverless": "^0.10.4",
		"@skeletonlabs/skeleton": "^4.0.0",
		"@skeletonlabs/skeleton-svelte": "^4.11.0",
		"drizzle-orm": "^0.39.3",
		"lucide-svelte": "^0.483.0",
		"netlify-identity-widget": "^1.9.2",
		"resend": "^4.1.2",
		"zod": "^3.24.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"netlify-cli",
			"sharp"
		],
		"ignoredBuiltDependencies": [
			"@parcel/watcher",
			"unix-dgram"
		],
		"overrides": {
			"esbuild@<=0.24.2": ">=0.25.0",
			"cookie@<0.7.0": ">=0.7.0",
			"svelte@>=5.53.0 <5.53.5": ">=5.53.5",
			"svelte@<=5.53.4": ">=5.53.5",
			"@sveltejs/kit@>=2.49.0 <=2.53.2": ">=2.53.3",
			"tar@<=7.5.9": ">=7.5.10",
			"svgo@=4.0.0": ">=4.0.1",
			"fastify@>=5.7.2 <=5.8.0": ">=5.8.1"
		}
	}
}
